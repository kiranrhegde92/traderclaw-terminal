# Angel One SmartAPI Credentials
ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_ID=your_client_id_here
ANGELONE_CLIENT_PIN=your_pin_here
ANGELONE_TOTP_SECRET=your_totp_secret_here

# Zerodha Kite Connect Credentials (OAuth — enter in /connect UI or add here)
# Get these from https://kite.trade/developers
# Set redirect URI in your Kite app to: http://localhost:3000/api/auth/zerodha/callback
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here

# News APIs (optional - free tier)
NEWS_API_KEY=your_newsapi_key_here

# Finnhub API for Fundamental Data (get free tier from https://finnhub.io)
# Required for: Fundamental Screener (PE, ROE, ROCE, Debt/Equity, etc.)
# Free tier: 60 API calls per minute
FINNHUB_API_KEY=your_finnhub_api_key_here

# App Config
NEXT_PUBLIC_APP_NAME=OpenClaw Terminal
NEXT_PUBLIC_VERSION=1.0.0
SESSION_SECRET=change_this_to_random_32_char_string

# Database path (defaults to ./data/openclaw.db)
DB_PATH=./data/openclaw.db
